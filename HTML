<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Sprout</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#e8f0e6; --bg2:#d7e6d3; --sill:#ecdcc2; --sill-edge:#dcc8a8;
    --pot:#d98a5b; --pot-dark:#c2734a;
    --leaf:#7cc45f; --leaf2:#8fce7f; --leaf-dry:#c7bb63; --leaf-dead:#9aa08f;
    --sun:#f4b940; --sun-dark:#d99f2b;
    --ink:#33402f; --ink-soft:#5f6d57;
    --card:#ffffff; --card-soft:#f4f9f2;
    --good:#6fbf5f; --mid:#f0b93a; --low:#e0674f;
    --water:#5ca4d6; --blush:#f4a1ae;
    --radius:18px; --shadow:0 10px 30px rgba(60,80,55,.14);
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{margin:0;height:100%}
  body{
    font-family:'Nunito',system-ui,sans-serif;color:var(--ink);
    background:linear-gradient(180deg,var(--bg) 0%,var(--bg2) 100%);
    min-height:100%;display:flex;align-items:center;justify-content:center;padding:16px;
  }
  .app{width:100%;max-width:440px;text-align:center}
  .brand{font-family:'Fredoka';font-weight:600;font-size:26px;letter-spacing:.5px;color:var(--ink)}
  .brand .dot{color:var(--sun-dark)}
  .tagline{font-size:13px;color:var(--ink-soft);margin-top:-2px;margin-bottom:10px}

  .scene{position:relative;background:var(--card);border-radius:24px;box-shadow:var(--shadow);
    padding:18px 18px 0;overflow:hidden}
  .daytag{position:absolute;top:14px;left:16px;font-family:'Fredoka';font-weight:600;font-size:15px;
    color:var(--ink-soft);background:var(--card-soft);padding:4px 12px;border-radius:999px;z-index:3}
  .plantname{position:absolute;top:14px;right:16px;font-size:13px;font-weight:700;color:var(--pot-dark);
    background:#fbeee4;padding:4px 12px;border-radius:999px;z-index:3;max-width:150px;
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .stage{position:relative;height:260px;display:flex;align-items:flex-end;justify-content:center}
  .stage svg{display:block;width:230px;height:100%;overflow:visible}
  .sill{height:26px;background:var(--sill);border-top:3px solid var(--sill-edge);
    margin:0 -18px;border-radius:0}

  .meters{display:flex;gap:12px;margin:14px 2px 0}
  .meter{flex:1;text-align:left}
  .meter .lbl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;
    color:var(--ink-soft);margin-bottom:5px;display:flex;justify-content:space-between}
  .bar{height:14px;border-radius:999px;background:#e7ede4;overflow:hidden;position:relative}
  .fill{height:100%;border-radius:999px;transition:width .5s ease,background .5s ease}
  .lbl .end{opacity:.55;font-weight:600}
  .moist{position:relative}
  .band-opt,.band-heal,.moist-marker{position:absolute;top:0;height:100%}
  .band-opt{background:rgba(111,191,95,.30)}
  .band-heal{background:rgba(111,191,95,.55)}
  .moist-marker{width:4px;background:var(--ink);border-radius:2px;transition:left .5s ease}

  .panel{background:var(--card);border-radius:24px;box-shadow:var(--shadow);
    margin-top:14px;padding:20px 18px}
  .panel h2{font-family:'Fredoka';font-weight:600;margin:0 0 6px;font-size:20px}
  .panel p{margin:6px 0;color:var(--ink-soft);font-size:15px;line-height:1.5}
  .big-num{font-family:'Fredoka';font-weight:600;font-size:52px;line-height:1;color:var(--sun-dark);
    margin:8px 0 2px}
  .big-num span{font-size:22px;color:var(--ink-soft)}
  .hint{font-size:13px;color:var(--ink-soft)}

  button{font-family:'Fredoka';font-weight:500;font-size:17px;border:none;cursor:pointer;
    border-radius:999px;padding:13px 22px;transition:transform .12s ease,box-shadow .12s ease;
    background:var(--sun);color:#5a4415;box-shadow:0 5px 0 var(--sun-dark)}
  button:active{transform:translateY(4px);box-shadow:0 1px 0 var(--sun-dark)}
  button.ghost{background:var(--card-soft);color:var(--ink-soft);box-shadow:0 5px 0 #d9e2d5}
  button.ghost:active{box-shadow:0 1px 0 #d9e2d5}
  button.wide{width:100%;margin-top:6px}
  .row{display:flex;gap:10px;margin-top:10px}
  .row button{flex:1}

  input[type=text]{font-family:'Nunito';font-weight:600;font-size:16px;text-align:center;
    border:2px solid #d9e2d5;border-radius:14px;padding:11px;width:100%;margin:8px 0;color:var(--ink);outline:none}
  input[type=text]:focus{border-color:var(--sun)}

  .arm-pulse{animation:pulse 1.6s ease-in-out infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.55}}
  @media (prefers-reduced-motion:reduce){.arm-pulse{animation:none}}

  .verdict{font-family:'Fredoka';font-weight:600;font-size:19px;margin:4px 0 2px}
  .v-heal{color:var(--good)} .v-safe{color:var(--ink)} .v-over{color:var(--water)} .v-dry{color:var(--pot-dark)}

  .lb{margin-top:8px;text-align:left}
  .lb-row{display:flex;justify-content:space-between;padding:9px 12px;border-radius:12px;font-size:14px}
  .lb-row:nth-child(odd){background:var(--card-soft)}
  .lb-row .rank{font-family:'Fredoka';font-weight:600;color:var(--ink-soft);width:26px}
  .lb-row .nm{flex:1;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .lb-row .dy{font-family:'Fredoka';font-weight:600;color:var(--sun-dark)}
  .note{font-size:12px;color:var(--ink-soft);margin-top:10px;line-height:1.4}

  .foot{margin-top:12px;display:flex;gap:14px;justify-content:center;align-items:center}
  .foot a{font-size:13px;color:var(--ink-soft);cursor:pointer;text-decoration:none;font-weight:600}
  .foot a:hover{color:var(--ink)}
  .death-msg{font-family:'Fredoka';font-weight:400;font-size:17px;line-height:1.5;color:var(--ink);
    background:var(--card-soft);border-radius:16px;padding:16px;margin:10px 0}
  .stat-line{font-size:14px;color:var(--ink-soft);margin:2px 0}
  .hidden{display:none}
</style>
</head>
<body>
<div class="app">
  <div class="brand">Spr<span class="dot">o</span>ut</div>
  <div class="tagline">one plant. your timing. that is the whole deal.</div>

  <div class="scene">
    <div class="daytag" id="daytag">Day 0</div>
    <div class="plantname" id="plantname"></div>
    <div class="stage" id="stage"></div>
    <div class="sill"></div>
  </div>

  <div class="meters" id="meters">
    <div class="meter">
      <div class="lbl"><span>Health</span><span id="healthPct">100</span></div>
      <div class="bar"><div class="fill" id="healthFill" style="width:100%;background:var(--good)"></div></div>
    </div>
    <div class="meter">
      <div class="lbl"><span class="end">dry</span><span>Soil</span><span class="end">wet</span></div>
      <div class="bar moist" id="moistBar">
        <div class="band-opt" id="bandOpt"></div>
        <div class="band-heal" id="bandHeal"></div>
        <div class="moist-marker" id="moistMarker" style="left:50%"></div>
      </div>
    </div>
  </div>

  <div class="panel" id="panel"></div>

  <div class="foot">
    <a id="lbLink">Leaderboard</a>
    <a id="muteLink">Sound: on</a>
  </div>
</div>

<script>
/* ============================================================
   SPROUT  -  configuration
   ------------------------------------------------------------
   Difficulty and balance live here. Tune freely, then playtest.
   The plant's true lifespan and the secret ending are NOT in
   this file on purpose. They live in Supabase so the ending
   cannot be read from the public GitHub source. See README.
   ============================================================ */
const CONFIG = {
  /* paste your Supabase project values here to switch on the
     global leaderboard and the hidden ending check. leave the
     placeholders and the game still runs fully, offline,
     with a local personal best only. */
  SUPABASE_URL: "YOUR_SUPABASE_URL",
  SUPABASE_ANON_KEY: "YOUR_SUPABASE_ANON_KEY",

  /* start asking the server whether the end has been reached
     only once a run is this old. keeps early play fully local
     and fast. this is NOT the lifespan, just a polite floor. */
  END_CHECK_AFTER: 60
};

/* ---- balance constants (moisture runs 0..100, ideal 50) ---- */
const B = {
  DRY_RATE: 1.0,        // moisture lost per second while closed
  WATER_BASE: 15,       // seconds of ideal interval on day 0
  WATER_GROWTH: 0.03,   // ideal interval grows as the plant ages
  WATER_MAX: 40,        // cap so counts stay humanly countable
  TARGET_MIN: 4,        // never ask for less than this many seconds

  OPT_START: 2.2,       // half width of the safe band on day 0
  OPT_FLOOR: 0.28,      // safe band shrinks toward the timing noise floor
  OPT_TAU: 200,         // higher = safe band shrinks slower

  HEAL_START: 0.85,     // half width of the healing band on day 0
  HEAL_END_DAY: 120,    // healing disappears entirely at this day

  DAMAGE_K: 1.7,        // damage scale for a watering outside the safe band
  DAMAGE_P: 1.7,        // superlinear: near-misses sting, big misses can gut you
  HEAL_AMOUNT: 1.6,     // health regained on a healing-band watering
  MIN_CLOSE: 0.8        // opens quicker than this count as a misfire
};

/* difficulty curves. optimal shrinks asymptotically and never
   reaches zero here, so the source looks like an endless game. */
function waterAmount(day){ return Math.min(B.WATER_MAX, B.WATER_BASE + B.WATER_GROWTH*day); }
function optimalHalf(day){ return B.OPT_FLOOR + (B.OPT_START-B.OPT_FLOOR)*Math.exp(-day/B.OPT_TAU); }
function healingHalf(day){ return Math.max(0, B.HEAL_START*(1 - day/B.HEAL_END_DAY)); }
function targetSeconds(moisture,day){
  return Math.max(B.TARGET_MIN, (moisture - 50 + waterAmount(day)) / B.DRY_RATE);
}

/* ============================================================
   death messages
   Selected by cause of death, days lived and watering accuracy,
   then a random theme is rolled on top. Add as many as you like.
   Tokens:  {d}=days  {p}=plant name
   cause: 'over' | 'dry' | 'any'   acc: 'precise' | 'sloppy' | 'any'
   ============================================================ */
const MESSAGES = [
  {th:'funny', cause:'over', max:8, t:"Drowned on day {d}. You loved {p} the way a golden retriever loves a swimming pool. Enthusiastically. Fatally."},
  {th:'funny', cause:'dry', max:8, t:"{p} died of thirst on day {d} and left a note. It reads: 'water. please. was that so hard.'"},
  {th:'funny', cause:'over', t:"{p} did not want a bath. {p} wanted a sip. There is a difference, and you have been informed of it on day {d}."},
  {th:'funny', cause:'dry', t:"The soil is a desert now. Tiny cacti are moving in. Day {d}, rest well, {p}."},
  {th:'funny', cause:'any', t:"Cause of death: your counting. {p} forgives you. The leaderboard does not."},
  {th:'funny', cause:'over', t:"You gave {p} so much water it briefly became a smoothie. Day {d}."},
  {th:'funny', cause:'dry', acc:'sloppy', t:"Your watering had the timing of a coin flip in a wind tunnel. {p} never stood a chance. Day {d}."},

  {th:'happy', cause:'any', min:20, t:"{d} good days. That is {d} more than most houseplants ever get. Nicely done."},
  {th:'happy', cause:'any', t:"It sprouted, it leafed, it thrived for a while. Ten out of ten. {p} would photosynthesize again."},
  {th:'happy', cause:'any', acc:'precise', min:40, t:"You were so gentle with {p}. It knew. Plants know these things. Day {d}, no regrets."},

  {th:'sad', cause:'dry', min:80, acc:'precise', t:"{d} days. You counted almost perfectly, almost every time. Almost is a dry word to die on."},
  {th:'sad', cause:'any', min:60, t:"{p} got used to you. That was the problem. Day {d}, and the windowsill feels bigger now."},
  {th:'sad', cause:'over', t:"{p} never knew it was drowning. It thought you were being generous. Day {d}."},
  {th:'sad', cause:'any', t:"Somewhere between day one and day {d}, {p} started trusting you. That is the sad part."},

  {th:'zen', cause:'dry', t:"Water comes, water goes. {p} held some for a while, then let it go. This too was watering. Be well."},
  {th:'zen', cause:'any', t:"{p} did not die. It simply returned to the great soil from which all pots are filled. Day {d}."},
  {th:'zen', cause:'any', t:"Impermanence has a smell. On day {d} it smells like a slightly damp pot. Breathe. Begin again."},

  {th:'gallows', cause:'over', t:"Waterlogged. Somewhere a cactus is watching this and laughing at both of us. Day {d}."},
  {th:'gallows', cause:'dry', t:"{p} is not dead. {p} is sustainably crispy. We do not say dead in this house. (It is dead. Day {d}.)"},
  {th:'gallows', cause:'any', t:"{p} has joined the compost bin, where it will finally get the drainage it always dreamed of. Day {d}."},
  {th:'gallows', cause:'any', t:"Good news: {p} is fertilizer now, so technically it helps the next one. Circle of life. Day {d}."},

  {th:'melodrama', cause:'any', min:120, acc:'precise', t:"So many flawless breaths undone by one careless one. This was not gardening. This was a Greek tragedy with chlorophyll. Day {d}."},
  {th:'melodrama', cause:'any', t:"{p} reached for the light for {d} days. On the {d}th, the light did not reach back."},
  {th:'melodrama', cause:'over', t:"You wept for {p}. Then you realized the wetness was just the overwatering. It is always the overwatering. Day {d}."},

  {th:'absurd', cause:'any', t:"{p} has died. Its final thought was about a specific cloud from day 19. You would not understand. Day {d}."},
  {th:'absurd', cause:'any', t:"{p} left everything to a distant fern named Gerald, who was not mentioned until now and is frankly thriving. Day {d}."},
  {th:'absurd', cause:'any', t:"Autopsy inconclusive. {p} appears to have died of vibes and a scheduling disagreement with you. Day {d}."},
  {th:'absurd', cause:'dry', t:"{p} crossed the desert of your forgetfulness for {d} days before lying down in the sand. A hero. A crispy, crispy hero."},

  {th:'kind', cause:'any', acc:'precise', t:"You were good at this. Genuinely. The universe simply required a plant and picked {p}. Day {d}."},
  {th:'kind', cause:'any', min:15, t:"{p} had a good life for a thing that lives on a windowsill. {d} days of being noticed. That counts."}
];

const PLANT_NAMES = ["Basil","Fern","Pip","Clover","Moss","Sage","Reed","Bud","Thistle","Juniper",
  "Pickle","Sprig","Bean","Pumpkin","Noodle","Kiwi","Waffle","Biscuit","Sprocket","Parsley","Olive","Gizmo"];

/* ============================================================
   the plant  (kawaii, reactive by mood + growth stage)
   ============================================================ */
const POT_BOTTOM_Y = 288;
const REPOT_DAYS = [3, 10, 28, 70, 160];   // days the plant is moved up to a bigger pot
const BLOOM_DAY = 35;                       // the first flower opens (its own moment)
function potTier(day){ let t=0; for(const d of REPOT_DAYS){ if(day>=d) t++; } return t; }   // 0..5
function stemHeight(day){ return 26 + 116*(1-Math.exp(-day/45)); }   // starts tiny, shoots up early, eases toward ~140
function leafPairs(day){ const th=[1,4,9,20,45,100]; let n=0; for(const t of th){ if(day>=t) n++; } return Math.min(n,6); }
function potGeom(tier){
  const topHalf=42+tier*6.5, height=90+tier*7;
  return {cx:115, topHalf, botHalf:topHalf*0.76, height, rimY:POT_BOTTOM_Y-height, botY:POT_BOTTOM_Y};
}
function moodFrom(moisture,health,day,dead){
  if(dead) return 'dead';
  if(health<25) return 'worried';
  const dev = moisture-50;
  if(Math.abs(dev)<=healingHalf(day)) return 'thriving';
  if(dev>optimalHalf(day)) return 'overwatered';
  if(dev<-optimalHalf(day)) return 'parched';
  return 'content';
}

function faceSVG(mood){
  // drawn around the origin (0,0); the caller translates and scales it onto the pot
  const ey=-10, my=14;
  let eyes='', mouth='', extra='';
  const blush=(c)=>`<circle cx="-30" cy="4" r="7" fill="${c}" opacity=".7"/><circle cx="30" cy="4" r="7" fill="${c}" opacity=".7"/>`;
  if(mood==='thriving'){
    eyes=`<path d="M -24 ${ey} q 8 -12 16 0" stroke="#fff" stroke-width="4" fill="none" stroke-linecap="round"/>
          <path d="M 8 ${ey} q 8 -12 16 0" stroke="#fff" stroke-width="4" fill="none" stroke-linecap="round"/>`;
    mouth=`<path d="M -14 ${my} q 14 15 28 0" stroke="#fff" stroke-width="4" fill="rgba(255,255,255,.25)" stroke-linecap="round"/>`;
    extra=blush('#f4a1ae')+sparkles();
  } else if(mood==='content'){
    eyes=dots(0,ey);
    mouth=`<path d="M -11 ${my} q 11 9 22 0" stroke="#fff" stroke-width="4" fill="none" stroke-linecap="round"/>`;
    extra=blush('#f4a1ae');
  } else if(mood==='overwatered'){
    eyes=`<path d="M -24 ${ey-4} q 8 10 16 0" stroke="#fff" stroke-width="4" fill="none" stroke-linecap="round"/>
          <path d="M 8 ${ey-4} q 8 10 16 0" stroke="#fff" stroke-width="4" fill="none" stroke-linecap="round"/>`;
    mouth=`<path d="M -13 ${my} q 6.5 -8 13 0 q 6.5 8 13 0" stroke="#fff" stroke-width="4" fill="none" stroke-linecap="round"/>`;
    extra=blush('#bfe0c4')+droplets();
  } else if(mood==='parched'){
    eyes=spiral(-16,ey)+spiral(16,ey);
    mouth=`<path d="M -9 ${my} q 9 -7 18 0" stroke="#fff" stroke-width="4" fill="none" stroke-linecap="round"/>`;
    extra=dryLines();
  } else if(mood==='worried'){
    eyes=dots(0,ey+1,3.6);
    mouth=`<path d="M -10 ${my+2} q 10 -8 20 0" stroke="#fff" stroke-width="4" fill="none" stroke-linecap="round"/>`;
    extra=`<path d="M -30 ${ey-12} l 15 6" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
           <path d="M 30 ${ey-12} l -15 6" stroke="#fff" stroke-width="3" stroke-linecap="round"/>`+sweat();
  } else {
    eyes=`<g stroke="#e7e2d8" stroke-width="4" stroke-linecap="round">
            <line x1="-25" y1="${ey-6}" x2="-13" y2="${ey+6}"/><line x1="-25" y1="${ey+6}" x2="-13" y2="${ey-6}"/>
            <line x1="13" y1="${ey-6}" x2="25" y2="${ey+6}"/><line x1="13" y1="${ey+6}" x2="25" y2="${ey-6}"/></g>`;
    mouth=`<line x1="-9" y1="${my}" x2="9" y2="${my}" stroke="#e7e2d8" stroke-width="4" stroke-linecap="round"/>`;
  }
  return eyes+mouth+extra;
  function dots(x,y,r){r=r||4.2;return `<circle cx="${x-16}" cy="${y}" r="${r}" fill="#fff"/><circle cx="${x+16}" cy="${y}" r="${r}" fill="#fff"/>`;}
  function spiral(x,y){let d=`M ${x} ${y}`;const steps=20,turns=1.7,maxR=6.5;
    for(let i=1;i<=steps;i++){const a=turns*2*Math.PI*i/steps,r=maxR*i/steps;d+=` L ${(x+r*Math.cos(a)).toFixed(1)} ${(y+r*Math.sin(a)).toFixed(1)}`;}
    return `<path d="${d}" stroke="#fff" stroke-width="2.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>`;}
  function sparkles(){return `<g fill="${getCSS('--sun')}">
      <path d="M -54 -44 l 3 7 l 7 3 l -7 3 l -3 7 l -3 -7 l -7 -3 l 7 -3 z"/>
      <path d="M 56 -34 l 2.4 5 l 5 2.4 l -5 2.4 l -2.4 5 l -2.4 -5 l -5 -2.4 l 5 -2.4 z"/></g>`;}
  function droplets(){return `<g fill="${getCSS('--water')}">
      <path d="M -42 8 q -6 8 0 12 q 6 -4 0 -12"/><path d="M 42 12 q -6 8 0 12 q 6 -4 0 -12"/></g>`;}
  function sweat(){return `<path d="M 40 8 q -6 8 0 12 q 6 -4 0 -12" fill="${getCSS('--water')}"/>`;}
  function dryLines(){return `<g stroke="#e8c98f" stroke-width="2.5" stroke-linecap="round" opacity=".85">
      <path d="M -44 12 l 9 3"/><path d="M 44 12 l -9 3"/></g>`;}
}
function getCSS(v){return getComputedStyle(document.documentElement).getPropertyValue(v).trim();}

function leavesSVG(day,mood,g){
  const dr = {thriving:.05,content:.12,overwatered:.55,parched:.75,worried:.55,dead:1}[mood];
  let col1='var(--leaf)', col2='var(--leaf2)';
  if(mood==='parched'||mood==='worried'){col1='var(--leaf-dry)';col2='#d2c672';}
  if(mood==='dead'){col1='var(--leaf-dead)';col2='#a8ad9c';}
  const cx=g.cx, tier=potTier(day), rimY=g.rimY;
  const topY=Math.max(34, rimY-stemHeight(day)), h=rimY-topY;   // clamp so the crown stays in frame
  const stemCol = mood==='dead'?'#8b917f':'#5f9e48';
  let s=`<path d="M ${cx} ${rimY} C ${cx} ${((rimY+topY)/2).toFixed(1)} ${cx} ${topY.toFixed(1)} ${cx} ${topY.toFixed(1)}"
           stroke="${stemCol}" stroke-width="${(5+tier*0.5).toFixed(1)}" fill="none" stroke-linecap="round"/>`;
  const pairs=leafPairs(day);
  for(let i=0;i<pairs;i++){                       // leaves fan out along the stem, biggest lowest
    const y=topY+((i+1)/(pairs+1))*h*0.9;
    const sz=0.7+0.12*i, sp=15+i*6;
    const a=(28+i*4)*(1-dr)-55*dr, yo=dr*14;
    s+=leaf(cx-sp,y+yo,15*sz,23*sz,-a,col1);
    s+=leaf(cx+sp,y+yo,15*sz,23*sz, a,col2);
  }
  if(S.bloomed && mood!=='dead'){                  // bloomed: a flower crowns the stem
    for(let i=0;i<5;i++){const ang=i*72;
      s+=`<ellipse cx="${cx}" cy="${(topY-11).toFixed(1)}" rx="6.5" ry="10" fill="#f6b3c4" transform="rotate(${ang} ${cx} ${topY.toFixed(1)})"/>`;}
    s+=`<circle cx="${cx}" cy="${topY.toFixed(1)}" r="6.5" fill="${getCSS('--sun')}"/>`;
  } else {                                         // young: a single sprout leaf on top
    s+=leaf(cx,topY-2,15,22,0,col2);
  }
  return s;
  function leaf(x,y,rx,ry,rot,c){return `<ellipse cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" rx="${rx.toFixed(1)}" ry="${ry.toFixed(1)}" fill="${c}" transform="rotate(${rot.toFixed(1)} ${x.toFixed(1)} ${y.toFixed(1)})"/>`;}
}

function potSVG(mood,g){
  let pot='var(--pot)', pd='var(--pot-dark)';
  if(mood==='overwatered'){pot='#c77c4d';pd='#a9663c';}
  const {cx,topHalf,botHalf,rimY,botY}=g;
  const lTop=cx-topHalf, rTop=cx+topHalf, lBot=cx-botHalf, rBot=cx+botHalf;
  return `
    <ellipse cx="${cx}" cy="${rimY}" rx="${(topHalf+5).toFixed(1)}" ry="${(topHalf*0.2).toFixed(1)}" fill="#5a3a24"/>
    <path d="M ${lTop.toFixed(1)} ${(rimY+2).toFixed(1)} Q ${lTop.toFixed(1)} ${(rimY-2).toFixed(1)} ${(lTop+4).toFixed(1)} ${(rimY-2).toFixed(1)} L ${(rTop-4).toFixed(1)} ${(rimY-2).toFixed(1)} Q ${rTop.toFixed(1)} ${(rimY-2).toFixed(1)} ${rTop.toFixed(1)} ${(rimY+2).toFixed(1)} L ${rBot.toFixed(1)} ${(botY-8).toFixed(1)} Q ${(rBot-1).toFixed(1)} ${botY} ${(rBot-9).toFixed(1)} ${botY} L ${(lBot+9).toFixed(1)} ${botY} Q ${(lBot+1).toFixed(1)} ${botY} ${lBot.toFixed(1)} ${(botY-8).toFixed(1)} Z" fill="${pot}"/>
    <ellipse cx="${cx}" cy="${(rimY+2).toFixed(1)}" rx="${(topHalf-5).toFixed(1)}" ry="${(topHalf*0.19).toFixed(1)}" fill="${pd}"/>
    <ellipse cx="${cx}" cy="${rimY}" rx="${(topHalf-8).toFixed(1)}" ry="${(topHalf*0.17).toFixed(1)}" fill="${pot}"/>`;
}

function renderPlant(){
  const dead = S.health<=0 || S.ended;
  const mood = moodFrom(S.moisture,S.health,S.day,dead);
  const g = potGeom(S.tier);
  const fs = (g.topHalf/50).toFixed(3);
  const faceY = (g.rimY + g.height*0.54).toFixed(1);
  const svg = `<svg viewBox="0 0 230 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Your plant, feeling ${mood}">
    ${leavesSVG(S.day,mood,g)}
    ${potSVG(mood,g)}
    <g transform="translate(${g.cx} ${faceY}) scale(${fs})">${faceSVG(mood)}</g>
  </svg>`;
  document.getElementById('stage').innerHTML = svg;
}

/* ============================================================
   sound  (tiny, optional, muteable)
   ============================================================ */
let AC=null, muted=false;
try{ muted = localStorage.getItem('sprout_muted')==='1'; }catch(e){}
function blip(freq,dur,type){
  if(muted) return;
  try{
    AC = AC || new (window.AudioContext||window.webkitAudioContext)();
    const o=AC.createOscillator(), g=AC.createGain();
    o.type=type||'sine'; o.frequency.value=freq;
    g.gain.value=.06; o.connect(g); g.connect(AC.destination);
    o.start(); g.gain.exponentialRampToValueAtTime(.0001,AC.currentTime+dur); o.stop(AC.currentTime+dur);
  }catch(e){}
}

/* ============================================================
   Supabase  (leaderboard + hidden ending). all optional.
   ============================================================ */
let sb=null;
const HAS_SB = CONFIG.SUPABASE_URL && !CONFIG.SUPABASE_URL.startsWith('YOUR_');
function initSB(){
  if(!HAS_SB || !window.supabase) return;
  try{ sb = window.supabase.createClient(CONFIG.SUPABASE_URL, CONFIG.SUPABASE_ANON_KEY); }catch(e){ sb=null; }
}
async function submitScore(name,days,avgErr,cause){
  if(!sb) return;
  try{ await sb.from('scores').insert({name:name.slice(0,24),days,avg_error:+avgErr.toFixed(2),cause}); }catch(e){}
}
async function fetchScores(){
  if(!sb) return null;
  try{
    const {data,error}=await sb.from('scores').select('name,days').order('days',{ascending:false}).limit(15);
    if(error) return null; return data;
  }catch(e){ return null; }
}
async function checkEnding(days){
  if(!sb || days<CONFIG.END_CHECK_AFTER) return null;
  try{
    const {data,error}=await sb.rpc('check_ending',{p_days:days});
    if(error||!data) return null; return data;   // the secret text, or null
  }catch(e){ return null; }
}

/* ============================================================
   device-aware wording: laptop on desktop, phone on mobile
   ============================================================ */
const IS_MOBILE = (function(){
  try{
    if(/Mobi|Android|iPhone|iPad|iPod|Windows Phone|IEMobile/i.test(navigator.userAgent)) return true;
    // iPadOS reports as desktop Safari, so also check for touch without a fine pointer
    return navigator.maxTouchPoints>1 && !(window.matchMedia&&window.matchMedia('(pointer:fine)').matches);
  }catch(e){ return false; }
})();
const DV = IS_MOBILE ? {
  ask:    'Lock your phone for about',
  cta:    'I am locking it now',
  instr:  'Lock your phone now',
  reopen: 'wake it again',
  intro:  'The game tells you how many seconds to keep your phone locked. Lock it, count in your head, and wake it right on time.',
  day0:   'First watering. Lock your phone, count the seconds in your head, and wake it right as you reach the mark.',
  tip:    'Tip: "lock your phone" means press the side button to turn the screen off, then wake it to open again.'
} : {
  ask:    'Close your laptop for about',
  cta:    'I am closing it now',
  instr:  'Close the laptop now',
  reopen: 'open it again',
  intro:  'The game tells you how many seconds to keep your laptop closed. Close it, count in your head, and open it right on time.',
  day0:   'First watering. Close the laptop, count the seconds in your head, and open it right as you reach the mark.',
  tip:    'Tip: on a phone, "close the laptop" means lock your screen instead.'
};

/* ============================================================
   game state + loop
   ============================================================ */
const S = {
  phase:'intro', day:0, moisture:50, health:100,
  name:'', plant:'', target:0, closeStamp:null,
  totalErr:0, rounds:0, earlyCount:0, lateCount:0, lastCause:'dry', ended:false,
  tier:0, pendingRepot:0
};
try{ S.name = localStorage.getItem('sprout_name')||''; }catch(e){}

function bestLocal(){ try{return JSON.parse(localStorage.getItem('sprout_best')||'null');}catch(e){return null;} }
function saveBest(days){
  const b=bestLocal();
  if(!b || days>b.days){ try{localStorage.setItem('sprout_best',JSON.stringify({days,name:S.name}));}catch(e){} }
}

function updateMeters(){
  document.getElementById('daytag').textContent = 'Day '+S.day;
  document.getElementById('plantname').textContent = S.plant?('🌱 '+S.plant):'';
  const h=Math.max(0,Math.round(S.health));
  document.getElementById('healthPct').textContent=h;
  const hf=document.getElementById('healthFill');
  hf.style.width=h+'%';
  hf.style.background = h>55?'var(--good)':h>25?'var(--mid)':'var(--low)';
  // moisture bar + shrinking bands
  const oh=optimalHalf(S.day), hh=healingHalf(S.day);
  document.getElementById('bandOpt').style.left=(50-oh)+'%';
  document.getElementById('bandOpt').style.width=(2*oh)+'%';
  document.getElementById('bandHeal').style.left=(50-hh)+'%';
  document.getElementById('bandHeal').style.width=(2*hh)+'%';
  document.getElementById('moistMarker').style.left='calc('+Math.max(0,Math.min(100,S.moisture))+'% - 2px)';
  renderPlant();
}

const panel=document.getElementById('panel');
function show(html){ panel.innerHTML=html; }

function screenIntro(){
  S.phase='intro';
  const b=bestLocal();
  show(`
    <h2>Meet your plant</h2>
    <p>Each day it needs watering. ${DV.intro}</p>
    <p><strong>Open early</strong> and you overwater. <strong>Open late</strong> and it goes thirsty. Miss too often and it dies. Keep it alive as long as you can.</p>
    <input type="text" id="nameInput" maxlength="24" placeholder="your name for the leaderboard" value="${S.name.replace(/"/g,'')}">
    <button class="wide" id="startBtn">Plant a seed</button>
    ${b?`<div class="note">Your longest life so far: <strong>${b.days} days</strong>.</div>`:''}
    <div class="note">${DV.tip}</div>
  `);
  document.getElementById('startBtn').onclick=()=>{
    const v=document.getElementById('nameInput').value.trim();
    S.name = v || 'Anonymous';
    try{localStorage.setItem('sprout_name',S.name);}catch(e){}
    startRun();
  };
}

const REPOT_MSG=[
  "{p} has outgrown its little starter pot. Time to move it somewhere roomier.",
  "Those roots are getting cramped again. {p} graduates to a proper pot.",
  "{p} is really taking off. Moving it up to a big pot.",
  "{p} needs a grand pot now. Not many plants ever get this big.",
  "{p} has reached a legendary size. The biggest pot in the house will have to do."
];

function startRun(){
  S.day=0; S.moisture=50; S.health=100; S.totalErr=0; S.rounds=0;
  S.earlyCount=0; S.lateCount=0; S.ended=false; S.tier=0; S.pendingRepot=0; S.bloomed=false; S.pendingBloom=false;
  S.plant = PLANT_NAMES[Math.floor(Math.random()*PLANT_NAMES.length)];
  updateMeters();
  screenPrompt();
}

function screenRepot(){
  S.phase='repot';
  updateMeters();
  const idx=Math.min(S.pendingRepot-1, REPOT_MSG.length-1);
  const msg=REPOT_MSG[idx].replace(/\{p\}/g,S.plant);
  show(`
    <h2>Time for a bigger pot</h2>
    <div class="death-msg" style="font-size:16px">${msg}</div>
    <button class="wide" id="potBtn">Settle ${S.plant} in</button>
  `);
  document.getElementById('potBtn').onclick=()=>{ S.tier=S.pendingRepot; S.pendingRepot=0; blip(620,.14); if(S.pendingBloom) return screenBloom(); screenPrompt(); };
}

function screenBloom(){
  S.phase='bloom';
  S.bloomed=true; S.pendingBloom=false;   // reveal the flower on this screen
  updateMeters();
  show(`
    <h2>${S.plant} has bloomed</h2>
    <div class="death-msg" style="font-size:16px">After all that careful timing, ${S.plant} has opened its very first flower. Most plants never get the chance. Take it in.</div>
    <button class="wide" id="bloomBtn">Admire it</button>
  `);
  document.getElementById('bloomBtn').onclick=()=>{ blip(780,.18); screenPrompt(); };
}

function screenPrompt(){
  S.phase='prompt';
  S.target = targetSeconds(S.moisture,S.day);
  updateMeters();
  const dev=S.moisture-50;
  let why;
  if(S.day===0){
    why=DV.day0;
  } else if(dev>0.6){
    why=`The soil is still wet from opening early last time, so the mark is longer now. Wait a bit more to let it dry back to just right.`;
  } else if(dev<-0.6){
    why=`The soil dried out from opening late last time, so the mark is shorter now. Open a bit sooner to catch it.`;
  } else {
    why=`Soil is right where it should be. Hold your timing steady and open on the mark.`;
  }
  show(`
    <h2>${S.plant} is ready for water</h2>
    <p>${DV.ask}</p>
    <div class="big-num">${S.target.toFixed(1)}<span>s</span></div>
    <p class="hint">${why}</p>
    <button class="wide" id="closeBtn">${DV.cta}</button>
  `);
  document.getElementById('closeBtn').onclick=()=>{ blip(520,.08); armClose(); };
}

function armClose(){
  S.phase='armed'; S.closeStamp=null;
  show(`
    <h2 class="arm-pulse">${DV.instr}</h2>
    <p>Aim to ${DV.reopen} in</p>
    <div class="big-num arm-pulse">${S.target.toFixed(1)}<span>s</span></div>
    <p class="hint">No peeking. Count it out.</p>
    <button class="ghost wide" id="cancelBtn">Cancel</button>
  `);
  document.getElementById('cancelBtn').onclick=()=>screenPrompt();
}

/* the core signal: page hidden = laptop closed / screen locked */
document.addEventListener('visibilitychange',()=>{
  if(S.phase!=='armed') return;
  if(document.hidden){
    if(S.closeStamp===null) S.closeStamp=Date.now();
  } else if(S.closeStamp!==null){
    const elapsed=(Date.now()-S.closeStamp)/1000;
    S.closeStamp=null;
    if(elapsed<B.MIN_CLOSE){ armClose(); return; } // misfire, let them try again
    resolveRound(elapsed);
  }
});

function resolveRound(elapsed){
  S.phase='resolving';
  const t=elapsed, tstar=S.target;
  const err=t-tstar;                       // >0 late (dry), <0 early (wet)
  if(err<0) S.earlyCount++; else S.lateCount++;
  S.totalErr+=Math.abs(err); S.rounds++;

  const dev=B.DRY_RATE*(tstar-t);          // >0 wet/overwatered, <0 dry/drought
  S.moisture=Math.max(0,Math.min(100,50+dev));
  const oh=optimalHalf(S.day), hh=healingHalf(S.day);
  const adev=Math.abs(dev);

  let verdict, vclass, delta=0;
  if(adev<=hh){ delta=+B.HEAL_AMOUNT; verdict=`${S.plant} is thriving`; vclass='v-heal'; blip(720,.12); }
  else if(adev<=oh){ verdict='Nicely timed'; vclass='v-safe'; blip(560,.08); }
  else{
    const dmg=B.DAMAGE_K*Math.pow(adev-oh,B.DAMAGE_P); delta=-dmg;
    if(dev>0){ verdict='Overwatered'; vclass='v-over'; S.lastCause='over'; blip(300,.18,'triangle'); }
    else{ verdict='Too dry'; vclass='v-dry'; S.lastCause='dry'; blip(260,.18,'sawtooth'); }
  }
  S.health=Math.max(0,Math.min(100,S.health+delta));
  S.day++;
  const nt=potTier(S.day);
  if(nt>S.tier){ S.pendingRepot=nt; }   // grew past its pot; actual move happens on the repot screen
  if(S.day>=BLOOM_DAY && !S.bloomed){ S.pendingBloom=true; }   // first flower is ready to open
  updateMeters();

  if(S.health<=0){ return death(); }

  const p=S.plant, diff=Math.abs(err).toFixed(1);
  const recap=`You opened at <strong>${t.toFixed(1)}s</strong>, and the mark was <strong>${tstar.toFixed(1)}s</strong>.`;
  let line;
  if(vclass==='v-heal'){
    line=`${recap} Just about perfect, so ${p} perked right up. Health <strong>+${delta.toFixed(1)}</strong>.`;
  } else if(vclass==='v-safe'){
    line=`${recap} Close enough that ${p} is fine. No health lost.`;
  } else if(vclass==='v-over'){
    line=`${recap} Opening ${diff}s early meant watering ${p} again too soon, so the soil is now waterlogged. Health <strong>${delta.toFixed(1)}</strong>. Wait a little longer next round.`;
  } else {
    line=`${recap} Opening ${diff}s late left ${p} thirsty for too long. Health <strong>${delta.toFixed(1)}</strong>. Open a little sooner next round.`;
  }
  show(`
    <div class="verdict ${vclass}">${verdict}</div>
    <p>${line}</p>
    <button class="wide" id="nextBtn">Next day</button>
  `);
  document.getElementById('nextBtn').onclick=async ()=>{
    // check the hidden ending once a run is old enough
    const secret=await checkEnding(S.day);
    if(secret){ return ending(secret); }
    if(S.pendingRepot){ return screenRepot(); }
    if(S.pendingBloom){ return screenBloom(); }
    screenPrompt();
  };
}

function accTier(){
  const avg=S.rounds?S.totalErr/S.rounds:99;
  return avg<1.5?'precise':avg>4?'sloppy':'ok';
}
function pickMessage(){
  const tier=accTier(), day=S.day, cause=S.lastCause;
  let pool=MESSAGES.filter(m=>
    (m.cause===cause||m.cause==='any') &&
    (m.min==null||day>=m.min) && (m.max==null||day<=m.max) &&
    (m.acc==null||m.acc==='any'||m.acc===tier));
  if(!pool.length) pool=MESSAGES.filter(m=>(m.cause===cause||m.cause==='any'));
  if(!pool.length) pool=MESSAGES;
  const m=pool[Math.floor(Math.random()*pool.length)];
  return m.t.replace(/\{d\}/g,day).replace(/\{p\}/g,S.plant);
}

async function death(){
  S.phase='dead';
  const days=S.day, avg=S.rounds?S.totalErr/S.rounds:0;
  saveBest(days);
  updateMeters();
  const msg=pickMessage();
  const tendency = S.earlyCount>S.lateCount?'you leaned toward opening early':'you leaned toward opening late';
  show(`
    <h2>${S.plant} has died</h2>
    <div class="death-msg">${msg}</div>
    <div class="stat-line">Lived <strong>${days} days</strong></div>
    <div class="stat-line">Average timing error: <strong>${avg.toFixed(1)}s</strong> · ${tendency}</div>
    <button class="wide" id="againBtn">Plant a new seed</button>
    <a class="note" id="viewLb" style="display:inline-block;margin-top:12px;cursor:pointer;font-weight:700;color:var(--ink-soft)">See the leaderboard</a>
  `);
  document.getElementById('againBtn').onclick=()=>startRun();
  document.getElementById('viewLb').onclick=()=>screenLeaderboard();
  submitScore(S.name,days,avg,S.lastCause);
}

function ending(secret){
  S.phase='ending'; S.ended=true; updateMeters(); blip(880,.5);
  show(`
    <h2>The end of a life</h2>
    <div class="death-msg" style="font-size:16px;white-space:pre-wrap">${(secret||'').toString()}</div>
    <div class="stat-line">${S.plant} lived a full and complete life. Almost no one gets here.</div>
    <button class="wide" id="againBtn">Begin again</button>
  `);
  document.getElementById('againBtn').onclick=()=>startRun();
  submitScore(S.name,S.day,S.rounds?S.totalErr/S.rounds:0,'lifespan');
}

async function screenLeaderboard(){
  S.phase='leaderboard';
  show(`<h2>Longest lives</h2><div class="lb" id="lbList"><p class="hint">Loading…</p></div>
        <button class="ghost wide" id="backBtn" style="margin-top:12px">Back</button>`);
  document.getElementById('backBtn').onclick=()=> S.day>0 && S.health>0 ? screenPrompt() : screenIntro();
  const data=await fetchScores();
  const list=document.getElementById('lbList');
  if(data && data.length){
    list.innerHTML=data.map((r,i)=>`<div class="lb-row"><span class="rank">${i+1}</span>
      <span class="nm">${escapeHtml(r.name)}</span><span class="dy">${r.days}d</span></div>`).join('');
  } else {
    const b=bestLocal();
    list.innerHTML=`<p class="hint">${HAS_SB?'No scores yet. Be the first.':'The global leaderboard turns on once Supabase is connected (see README).'}</p>
      ${b?`<div class="lb-row"><span class="rank">You</span><span class="nm">${escapeHtml(b.name||'you')}</span><span class="dy">${b.days}d</span></div>`:''}`;
  }
}
function escapeHtml(s){return (s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));}

/* footer */
document.getElementById('lbLink').onclick=()=>screenLeaderboard();
const muteLink=document.getElementById('muteLink');
function paintMute(){ muteLink.textContent='Sound: '+(muted?'off':'on'); }
muteLink.onclick=()=>{ muted=!muted; try{localStorage.setItem('sprout_muted',muted?'1':'0');}catch(e){} paintMute(); };
paintMute();

/* boot */
function boot(){ initSB(); updateMeters(); screenIntro(); }
if(HAS_SB){
  const s=document.createElement('script');
  s.src='https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js';
  s.onload=boot; s.onerror=boot; document.head.appendChild(s);
} else { boot(); }
</script>
